# Copy to .env and fill in your credentials.
# .env is gitignored; this file is not.

# ---------------------------------------------------------------------------
# Option A: EPAM DIAL proxy (requires EPAM VPN)
# ---------------------------------------------------------------------------

# EPAM DIAL proxy base URL (no trailing slash)
DIAL_BASE_URL=https://ai-proxy.lab.epam.com

# DIAL API token (from EPAM AI DIAL portal)
DIAL_TOKEN=your-dial-token-here

# Chat model deployment name
DIAL_CHAT_MODEL=gpt-4o

# Embedding model deployment name (text-embedding-005 confirmed working, 768-dim)
DIAL_EMBEDDING_MODEL=text-embedding-005

# ---------------------------------------------------------------------------
# Option B: Direct OpenAI API (no VPN required)
# If OPENAI_API_KEY is set, it takes priority over DIAL_TOKEN.
# ---------------------------------------------------------------------------

# OpenAI API key (from platform.openai.com)
# OPENAI_API_KEY=sk-...

# Chat model (default: gpt-4o)
# OPENAI_CHAT_MODEL=gpt-4o

# Embedding model (default: text-embedding-3-small, 1536-dim)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Optional: protect the app with a password (leave empty to disable)
# ---------------------------------------------------------------------------
APP_PASSWORD=
